# =============================================================================
# WeekPilot — Environment Variables (EXAMPLE / TEMPLATE)
# =============================================================================
# Copy this file to .env and fill in your own values:
#     Windows : copy .env.example .env
#     macOS/Linux : cp .env.example .env
#
# NEVER commit your real .env — it is git-ignored on purpose.
# On Kaggle, use Kaggle Secrets (Add-ons -> Secrets) instead of a .env file.
# =============================================================================

# Google AI Studio API Key (required)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-studio-api-key-here

# Optional: override the default Gemini model (applies to all agents)
# WEEKPILOT_MODEL=gemini-2.5-flash

# Optional: set log level (DEBUG, INFO, WARNING, ERROR)
# WEEKPILOT_LOG_LEVEL=INFO
